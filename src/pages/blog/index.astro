---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Blog" description="Thoughts on AI, research, and building intelligent agents">
  <section class="pt-24 pb-16">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <!-- Header -->
      <header class="mb-16 reveal">
        <h1 class="heading-1 text-stone-900 dark:text-stone-50 mb-4">Blog</h1>
        <p class="text-stone-500 dark:text-stone-400 max-w-xl leading-relaxed">
          Thoughts on AI agents, reinforcement learning, and the journey of building intelligent systems.
        </p>
      </header>

      <!-- Posts List -->
      {posts.length > 0 ? (
        <div class="space-y-6">
          {posts.map((post) => (
            <article class="card card-hover p-6 md:p-8 group reveal">
              <a href={post.data.externalUrl || `/blog/${post.slug}/`} target={post.data.externalUrl ? "_blank" : undefined} rel={post.data.externalUrl ? "noopener noreferrer" : undefined} class="block">
                <div class="flex flex-col md:flex-row md:items-start gap-4 md:gap-6">
                  {post.data.heroImage && (
                    <div class="flex-shrink-0 w-full md:w-48 h-32 rounded-lg overflow-hidden">
                      <img
                        src={post.data.heroImage}
                        alt={post.data.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      />
                    </div>
                  )}
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2">
                      <time
                        datetime={post.data.pubDate.toISOString()}
                        class="text-xs text-stone-400 dark:text-stone-500"
                      >
                        {post.data.pubDate.toLocaleDateString('en-US', {
                          year: 'numeric',
                          month: 'long',
                          day: 'numeric',
                        })}
                      </time>
                      {post.data.externalUrl && (
                        <span class="inline-flex items-center gap-1 text-xs px-2 py-0.5 bg-accent-50 dark:bg-accent-950/50 text-accent-600 dark:text-accent-400 rounded-full border border-accent-200 dark:border-accent-500/20">
                          Amazon Science
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                        </span>
                      )}
                    </div>
                    <h2 class="heading-3 text-stone-900 dark:text-stone-100 mt-2 mb-3 group-hover:text-accent-700 dark:group-hover:text-accent-400 transition-colors duration-300">
                      {post.data.title}
                    </h2>
                    <p class="text-stone-500 dark:text-stone-400 line-clamp-2 text-sm leading-relaxed">
                      {post.data.description}
                    </p>
                    {post.data.tags && post.data.tags.length > 0 && (
                      <div class="flex flex-wrap gap-2 mt-4">
                        {post.data.tags.slice(0, 3).map((tag) => (
                          <span class="px-2.5 py-0.5 bg-stone-100 dark:bg-stone-800/50 text-stone-500 dark:text-stone-400 text-xs rounded-full">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-20 reveal">
          <div class="w-14 h-14 mx-auto mb-6 rounded-xl bg-stone-100 dark:bg-stone-800/50 flex items-center justify-center">
            <svg class="w-7 h-7 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
            </svg>
          </div>
          <h2 class="font-serif text-xl text-stone-900 dark:text-stone-100 mb-2">No posts yet</h2>
          <p class="text-stone-500 dark:text-stone-400 text-sm">
            Check back soon for new articles.
          </p>
        </div>
      )}
    </div>
  </section>
</Layout>
